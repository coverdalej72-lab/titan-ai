# Titan AI Environment Configuration

# Stripe (required for payments)
STRIPE_SECRET_KEY=sk_test_...your_stripe_secret_key...
STRIPE_WEBHOOK_SECRET=whsec_...your_webhook_secret...

# AI Brain (required for real AI responses)
# Either Anthropic or OpenAI (or both)
ANTHROPIC_API_KEY=sk-ant-...your_anthropic_key...
OPENAI_API_KEY=sk-...your_openai_key...

# Site URL (for Stripe redirects)
SITE_URL=http://localhost:3000

# Optional: Email (for future email integration)
# GMAIL_USER=your-email@gmail.com
# GMAIL_APP_PASSWORD=your-app-password

# Optional: Twilio (for SMS)
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+61...
